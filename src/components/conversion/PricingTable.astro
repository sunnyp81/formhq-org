---
import { getLLCProviders, getLLCProviderUrl, formatCurrency } from '../../lib/data';
import type { State } from '../../lib/data';

interface Props {
  state: State;
}

const { state } = Astro.props;
const providers = getLLCProviders();
---

<section class="my-10">
  <h2 class="text-2xl font-bold mb-6">Best LLC Formation Services in {state.name}</h2>

  <div class="hidden md:block overflow-x-auto">
    <table class="w-full border-collapse">
      <thead>
        <tr class="bg-gray-50">
          <th class="text-left p-3 font-semibold text-sm">Provider</th>
          <th class="text-left p-3 font-semibold text-sm">Total Cost</th>
          <th class="text-left p-3 font-semibold text-sm">Includes</th>
          <th class="text-center p-3 font-semibold text-sm">Rating</th>
          <th class="text-center p-3 font-semibold text-sm"></th>
        </tr>
      </thead>
      <tbody>
        {providers.map((provider) => (
          <tr class:list={['border-t border-gray-200', { 'bg-accent-50': provider.isTopPick }]}>
            <td class="p-3">
              <div class="flex items-center gap-2">
                {provider.isTopPick && (
                  <span class="inline-block px-2 py-0.5 bg-accent-500 text-white text-xs font-bold rounded">Top Pick</span>
                )}
                <span class="font-medium">{provider.name}</span>
              </div>
            </td>
            <td class="p-3">
              <span class="font-bold text-lg">{formatCurrency(provider.basePrice + state.llcFilingFee)}</span>
              <span class="text-xs text-gray-500 block">
                {formatCurrency(provider.basePrice)} + {formatCurrency(state.llcFilingFee)} state fee
              </span>
            </td>
            <td class="p-3">
              <ul class="text-sm text-gray-600 space-y-1">
                {provider.features.map((f) => (
                  <li class="flex items-start gap-1">
                    <span class="text-accent-500 mt-0.5">&#10003;</span>
                    {f}
                  </li>
                ))}
              </ul>
            </td>
            <td class="p-3 text-center">
              <span class="font-bold">{provider.rating}</span><span class="text-gray-400">/5</span>
            </td>
            <td class="p-3 text-center">
              <a
                href={getLLCProviderUrl(provider, state.abbr)}
                target="_blank"
                rel="nofollow sponsored noopener noreferrer"
                class="inline-block px-4 py-2 bg-primary-600 text-white text-sm font-medium rounded-md hover:bg-primary-700 transition-colors"
              >
                Visit {provider.name}
              </a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="md:hidden space-y-4">
    {providers.map((provider) => (
      <div class:list={['rounded-lg border p-4', provider.isTopPick ? 'border-accent-300 bg-accent-50' : 'border-gray-200']}>
        <div class="flex items-center justify-between mb-3">
          <div class="flex items-center gap-2">
            {provider.isTopPick && (
              <span class="inline-block px-2 py-0.5 bg-accent-500 text-white text-xs font-bold rounded">Top Pick</span>
            )}
            <span class="font-semibold">{provider.name}</span>
          </div>
          <span class="text-sm font-bold">{provider.rating}/5</span>
        </div>
        <p class="text-2xl font-bold text-primary-700 mb-1">{formatCurrency(provider.basePrice + state.llcFilingFee)}</p>
        <p class="text-xs text-gray-500 mb-3">{formatCurrency(provider.basePrice)} + {formatCurrency(state.llcFilingFee)} state fee</p>
        <ul class="text-sm text-gray-600 space-y-1 mb-4">
          {provider.features.map((f) => (
            <li class="flex items-start gap-1">
              <span class="text-accent-500">&#10003;</span>
              {f}
            </li>
          ))}
        </ul>
        <a
          href={getLLCProviderUrl(provider, state.abbr)}
          target="_blank"
          rel="nofollow sponsored noopener noreferrer"
          class="block text-center px-4 py-2 bg-primary-600 text-white text-sm font-medium rounded-md hover:bg-primary-700 transition-colors"
        >
          Visit {provider.name}
        </a>
      </div>
    ))}
  </div>
</section>
