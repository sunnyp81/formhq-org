---
import { breadcrumbSchema, canonicalUrl } from '../../lib/seo';

interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const schemaItems = items.map((item) => ({
  name: item.label,
  url: canonicalUrl(item.href),
}));

const schema = breadcrumbSchema(schemaItems);
---

<nav aria-label="Breadcrumb" class="text-sm text-gray-500 mb-6">
  <ol class="flex flex-wrap items-center gap-1">
    {items.map((item, index) => (
      <li class="flex items-center gap-1">
        {index > 0 && <span aria-hidden="true">/</span>}
        {index === items.length - 1 ? (
          <span aria-current="page" class="text-gray-800 font-medium">{item.label}</span>
        ) : (
          <a href={item.href} class="hover:text-primary-600 underline">{item.label}</a>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
