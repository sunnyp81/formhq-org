---
import { getAllStates } from '../../lib/data';
import type { BusinessType } from '../../lib/data';

interface Props {
  business: BusinessType;
  linkPrefix?: string;
}

const { business, linkPrefix = '/start' } = Astro.props;
const states = getAllStates();
---

<section class="my-10">
  <h2 class="text-2xl font-bold mb-6">Start a {business.name} by State</h2>
  <nav aria-label="Select a state">
    <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2">
      {states.map((state) => (
        <li>
          <a
            href={`${linkPrefix}/${business.slug}/${state.slug}/`}
            class="block px-3 py-2 text-sm rounded-md border border-gray-200 hover:border-primary-300 hover:bg-primary-50 transition-colors"
          >
            {state.name} ({state.abbr})
          </a>
        </li>
      ))}
    </ul>
  </nav>
</section>
