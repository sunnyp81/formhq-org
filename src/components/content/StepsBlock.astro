---
import type { Step } from '../../lib/data';

interface Props {
  steps: Step[];
  title?: string;
}

const { steps, title = 'Steps to Get Started' } = Astro.props;
---

<section class="my-10">
  <h2 class="text-2xl font-bold mb-6">{title}</h2>
  <ol class="space-y-6">
    {steps.map((step) => (
      <li class="flex gap-4">
        <span class="shrink-0 w-8 h-8 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center font-bold text-sm">
          {step.order}
        </span>
        <div>
          <h3 class="font-semibold text-lg">{step.title}</h3>
          <p class="text-gray-600 mt-1">{step.description}</p>
        </div>
      </li>
    ))}
  </ol>
</section>
