---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import { getAllStates, formatCurrency } from '../../lib/data';
import { canonicalUrl, webPageSchema } from '../../lib/seo';

const title = 'Form an LLC — State-by-State Guides & Best Services';
const description = 'Compare LLC filing fees, requirements, and the best formation services across all 50 states. Step-by-step guides to form your LLC.';
const url = canonicalUrl('/llc');
const schemas = [webPageSchema(title, description, url)];
const states = getAllStates();
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Form an LLC', href: '/llc/' },
];
---

<BaseLayout title={title} description={description} canonicalUrl={url} schemas={schemas}>
  <div class="max-w-4xl mx-auto px-4 py-10">
    <Breadcrumbs items={breadcrumbs} />
    <h1 class="text-4xl font-bold mb-4">Form an LLC</h1>
    <p class="text-lg text-gray-600 mb-8">Compare filing fees and requirements across states, and find the best LLC formation service for you.</p>

    <section class="my-10">
      <h2 class="text-2xl font-bold mb-6">LLC Filing Fees by State</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse">
          <thead>
            <tr class="bg-gray-50">
              <th class="text-left p-3 font-semibold text-sm">State</th>
              <th class="text-left p-3 font-semibold text-sm">Filing Fee</th>
              <th class="text-left p-3 font-semibold text-sm">Annual Fee</th>
              <th class="text-left p-3 font-semibold text-sm">Income Tax</th>
              <th class="text-center p-3 font-semibold text-sm"></th>
            </tr>
          </thead>
          <tbody>
            {states.map((s) => (
              <tr class="border-t border-gray-200">
                <td class="p-3 font-medium">{s.name} ({s.abbr})</td>
                <td class="p-3">{formatCurrency(s.llcFilingFee)}</td>
                <td class="p-3">{s.annualReportFee > 0 ? formatCurrency(s.annualReportFee) : 'None'}</td>
                <td class="p-3">{s.hasStateIncomeTax ? 'Yes' : 'None'}</td>
                <td class="p-3 text-center">
                  <a href={`/llc/${s.slug}/`} class="text-primary-600 hover:underline text-sm font-medium">
                    Full guide &rarr;
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </div>
</BaseLayout>
