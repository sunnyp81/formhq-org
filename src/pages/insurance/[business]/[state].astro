---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import Breadcrumbs from '../../../components/layout/Breadcrumbs.astro';
import FAQBlock from '../../../components/content/FAQBlock.astro';
import RelatedLinks from '../../../components/navigation/RelatedLinks.astro';
import {
  getBusinessStatePairs,
  getInsuranceTypesForBusiness,
  formatCostRange,
} from '../../../lib/data';
import {
  insuranceSpokeTitle,
  insuranceSpokeDescription,
  canonicalUrl,
  webPageSchema,
} from '../../../lib/seo';
import type { BusinessType, State } from '../../../lib/data';

export function getStaticPaths() {
  return getBusinessStatePairs().map(({ business, state }) => ({
    params: { business: business.slug, state: state.slug },
    props: { business, state },
  }));
}

interface Props {
  business: BusinessType;
  state: State;
}

const { business, state } = Astro.props;
const title = insuranceSpokeTitle(business, state);
const description = insuranceSpokeDescription(business, state);
const url = canonicalUrl(`/insurance/${business.slug}/${state.slug}`);
const insuranceTypes = getInsuranceTypesForBusiness(business);

const schemas = [webPageSchema(title, description, url)];

const faqs = [
  {
    question: `How much does ${business.name.toLowerCase()} insurance cost in ${state.name}?`,
    answer: `The cost varies based on coverage type and business size. General liability typically costs ${formatCostRange(insuranceTypes[0]?.avgAnnualCost ?? [400, 1500])} per year.`,
  },
  {
    question: `Is insurance required for a ${business.name.toLowerCase()} in ${state.name}?`,
    answer: `General liability insurance is strongly recommended. Workers' compensation is ${state.insuranceMinimums['workers-comp'] === 'required-with-employees' ? 'required if you have employees' : 'required with 4 or more employees'} in ${state.name}.`,
  },
  {
    question: `What type of insurance does a ${business.name.toLowerCase()} need?`,
    answer: `Most ${business.name.toLowerCase()} operations need ${insuranceTypes.map((i) => i.shortName.toLowerCase()).join(', ')} coverage at minimum.`,
  },
];

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Insurance', href: '/insurance/' },
  { label: business.name, href: `/start/${business.slug}/` },
  { label: state.name, href: `/insurance/${business.slug}/${state.slug}/` },
];

const utmParams = `?utm_source=bizformation&utm_medium=cta&utm_campaign=${business.slug}-${state.slug}`;
---

<BaseLayout title={title} description={description} canonicalUrl={url} schemas={schemas}>
  <article class="max-w-4xl mx-auto px-4 py-10">
    <Breadcrumbs items={breadcrumbs} />

    <h1 class="text-4xl font-bold mb-4">{title}</h1>
    <p class="text-lg text-gray-600 mb-8">
      Protect your {business.name.toLowerCase()} in {state.name} with the right insurance coverage. Compare policies and get free quotes.
    </p>

    <section class="my-10">
      <h2 class="text-2xl font-bold mb-6">Required & Recommended Coverage</h2>
      <div class="space-y-4">
        {insuranceTypes.map((ins) => (
          <div class="p-4 border border-gray-200 rounded-lg">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-semibold text-lg">{ins.name}</h3>
              <span class={`px-2 py-0.5 text-xs font-medium rounded ${ins.isTypicallyRequired ? 'bg-red-100 text-red-700' : 'bg-yellow-100 text-yellow-700'}`}>
                {ins.isTypicallyRequired ? 'Required' : 'Recommended'}
              </span>
            </div>
            <p class="text-gray-600 text-sm mb-2">{ins.description}</p>
            <p class="text-sm">
              <span class="font-medium">Estimated annual cost:</span>
              <span class="text-primary-700"> {formatCostRange(ins.avgAnnualCost)}</span>
            </p>
            {state.insuranceMinimums[ins.slug] && (
              <p class="text-sm mt-1">
                <span class="font-medium">{state.name} minimum:</span>
                <span class="text-primary-700">
                  {typeof state.insuranceMinimums[ins.slug] === 'number'
                    ? `$${(state.insuranceMinimums[ins.slug] as number).toLocaleString()} coverage`
                    : state.insuranceMinimums[ins.slug]}
                </span>
              </p>
            )}
          </div>
        ))}
      </div>
    </section>

    <div class="my-8 p-6 bg-accent-50 border border-accent-200 rounded-lg text-center">
      <h3 class="text-xl font-bold mb-2">Ready to Get Covered?</h3>
      <p class="text-gray-600 mb-4">Compare {business.name.toLowerCase()} insurance quotes from top providers in {state.name}.</p>
      <a
        href={`#${utmParams}`}
        target="_blank"
        rel="nofollow sponsored noopener noreferrer"
        class="inline-block px-6 py-3 bg-accent-600 text-white font-medium rounded-md hover:bg-accent-700 transition-colors"
      >
        Get Free Quotes
      </a>
      <p class="text-xs text-gray-400 mt-2">No obligation. Compare quotes from multiple insurers.</p>
    </div>

    <section class="my-10">
      <h2 class="text-2xl font-bold mb-4">Also Consider</h2>
      <p class="text-gray-600">
        Before getting insured, make sure your business is properly formed.
        <a href={`/llc/${state.slug}/`} class="text-primary-600 hover:underline">Form your LLC in {state.name}</a>
        or
        <a href={`/start/${business.slug}/${state.slug}/`} class="text-primary-600 hover:underline">see the full startup guide for {state.name}</a>.
      </p>
    </section>

    <FAQBlock faqs={faqs} />

    <RelatedLinks business={business} state={state} pageType="insurance-spoke" />
  </article>
</BaseLayout>
